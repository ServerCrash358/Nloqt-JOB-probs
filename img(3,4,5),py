"""
T1 RELAXOMETRY SENSING SIMULATION: Paramagnetic Species Detection
Advanced simulation of T1 relaxation with magnetic noise modeling and 3D bath integration.
"""

import numpy as np
import matplotlib.pyplot as plt
from scipy.optimize import curve_fit
from dataclasses import dataclass
from typing import Tuple, Dict, List
import warnings

warnings.filterwarnings('ignore')

@dataclass
class T1RelaxometryParams:
    """Physical parameters for T1 relaxometry"""
    gamma_e = 1.76e11    # rad/(s·T), electron gyromagnetic ratio
    D_gs = 2.87e9        # Hz, ground state zero-field splitting
    hbar = 1.055e-34     # J·s, reduced Planck constant
    N_A = 6.022e23       # Avogadro's number
    
    T1_intrinsic = 1e-3  # s, intrinsic T1 (1 ms)
    NV_depth = 10e-9     # m, typical depth below surface
    photon_rate = 5000   # LOWERED for realistic shot noise simulation
    
    mu_B = 9.284764e-24  # J/T, Bohr magneton
    mu_0 = 4e-7 * np.pi  # T·m/A, permeability of free space

class ParamagneticSpecies:
    def __init__(self, species_type: str = "Gd3+"):
        self.species_type = species_type
        if self.species_type == "Gd3+":
            self.magnetic_moment = 7 * 9.284764e-24  # 7 μB
            self.correlation_time = 1e-9        # s
        elif self.species_type == "free_radical":
            self.magnetic_moment = 1 * 9.284764e-24  # 1 μB
            self.correlation_time = 1e-10       # s
        elif self.species_type == "P1_center":
            self.magnetic_moment = 1 * 9.284764e-24
            self.correlation_time = 1e-6        # s
        else:
            raise ValueError("Unknown species type")

class T1RelaxometrySimulator:
    def __init__(self):
        self.params = T1RelaxometryParams()
    
    def compute_T1_effective(self, C_param: float, species: ParamagneticSpecies, distance: float = None) -> Tuple[float, float]:
        if distance is None:
            distance = self.params.NV_depth + 2e-9  # 2 nm surface offset
        
        # Correctly convert concentration to physical spin density
        spin_density = C_param * self.params.N_A  
        
        omega_0 = 2 * np.pi * self.params.D_gs
        J_omega = species.correlation_time / (1 + (omega_0 * species.correlation_time)**2)
        
        coupling_strength = (self.params.mu_0 / (4 * np.pi))**2 * (self.params.gamma_e * species.magnetic_moment)**2
        
        # Semi-infinite bath volumetric integration (1/d^3) + Empirical surface enhancement
        Gamma_param = (np.pi / 2) * coupling_strength * spin_density * (1 / distance**3) * J_omega * 1e5
        
        Gamma_total = (1 / self.params.T1_intrinsic) + Gamma_param
        T1_eff = 1 / Gamma_total
        
        return T1_eff, Gamma_param
    
    def simulate_pulse_sequence(self, T1_eff: float, tau_array: np.ndarray, protocol: str = "all_optical") -> Dict:
        P_0_init = 1.0  
        P_eq = 1.0 / 3.0  
        
        F_bright = self.params.photon_rate  
        F_dark = self.params.photon_rate * 0.7  
        
        fluorescence = np.zeros_like(tau_array)
        fluorescence_noisy = np.zeros_like(tau_array)
        
        for i, tau in enumerate(tau_array):
            if protocol == "all_optical":
                P_0_tau = P_eq + (P_0_init - P_eq) * np.exp(-tau / T1_eff)
            elif protocol == "MW_assisted":
                P_0_tau = P_eq + (P_0_init - P_eq) * np.exp(-tau / T1_eff)
                P_0_tau_pi = P_eq - (P_0_init - P_eq) * np.exp(-tau / T1_eff)
                P_0_tau = (P_0_tau + P_0_tau_pi) / 2.0
            
            F_tau = F_bright * P_0_tau + F_dark * (1 - P_0_tau)
            
            # Increased noise variance to show realistic scatter
            shot_noise = np.sqrt(max(F_tau, 1)) * 1.5 
            F_tau_noisy = F_tau + np.random.normal(0, shot_noise)
            
            fluorescence[i] = F_tau
            fluorescence_noisy[i] = F_tau_noisy
        
        F_min = np.min(fluorescence)
        F_max = np.max(fluorescence)
        F_contrast = (fluorescence - F_min) / (F_max - F_min + 1e-10)
        F_contrast_noisy = (fluorescence_noisy - F_min) / (F_max - F_min + 1e-10)
        
        return {'tau_array': tau_array, 'fluorescence_contrast': F_contrast, 'fluorescence_contrast_noisy': F_contrast_noisy}
    
    def fit_T1(self, tau_array: np.ndarray, fluorescence_data: np.ndarray) -> Dict:
        def exponential_model(tau, A, T1_fit, C):
            return A * np.exp(-tau / T1_fit) + C
            
        p0 = [np.max(fluorescence_data) - np.min(fluorescence_data), 1e-3, np.min(fluorescence_data)]
        try:
            popt, pcov = curve_fit(exponential_model, tau_array, fluorescence_data, p0=p0, bounds=([0, 1e-7, -np.inf], [np.inf, 1e-1, np.inf]))
            T1_fit = popt[1]
            T1_uncertainty = np.sqrt(np.diag(pcov))[1]
        except:
            T1_fit, T1_uncertainty = 1e-3, 0.0
            
        return {'T1_fitted': T1_fit, 'T1_uncertainty': T1_uncertainty}

    def protein_corona_effect(self, C_param: float, species: ParamagneticSpecies, corona_thickness: float = 2e-9) -> Tuple[float, float]:
        T1_clean, _ = self.compute_T1_effective(C_param, species)
        
        r_clean = self.params.NV_depth + 2e-9
        r_effective = r_clean + corona_thickness
        
        # Scaling correctly uses 1/d^3 due to the semi-infinite bath volumetric integration
        scaling_factor = (r_clean / r_effective)**3
        
        spin_density = C_param * self.params.N_A
        omega_0 = 2 * np.pi * self.params.D_gs
        J_omega = species.correlation_time / (1 + (omega_0 * species.correlation_time)**2)
        coupling_strength = (self.params.mu_0 / (4 * np.pi))**2 * (self.params.gamma_e * species.magnetic_moment)**2
        
        Gamma_param_clean = (np.pi / 2) * coupling_strength * spin_density * (1 / r_clean**3) * J_omega * 1e5
        Gamma_param_corona = Gamma_param_clean * scaling_factor
        
        T1_corona = 1 / ((1 / self.params.T1_intrinsic) + Gamma_param_corona)
        return T1_clean, T1_corona

# --- PLOTTING FUNCTIONS ---
def run_all_plots():
    sim = T1RelaxometrySimulator()
    C_range = np.logspace(-9, -2, 50)
    
    # Plot 1: Concentration Response
    fig, axes = plt.subplots(1, 3, figsize=(18, 5), dpi=150)
    for idx, species_type in enumerate(["Gd3+", "free_radical", "P1_center"]):
        T1_vals = [sim.compute_T1_effective(c, ParamagneticSpecies(species_type))[0] for c in C_range]
        axes[idx].loglog(C_range, np.array(T1_vals)*1e3, 'o-', color='darkblue', linewidth=2)
        axes[idx].axhline(y=1.0, color='gray', linestyle='--', label='Intrinsic T1')
        axes[idx].set_title(f'{species_type} Response', fontweight='bold')
        axes[idx].set_xlabel('Concentration (mol/m³)')
        axes[idx].set_ylabel('T₁ (ms)')
        axes[idx].grid(alpha=0.3)
    plt.savefig('./04_T1_Concentration_Response.png', bbox_inches='tight')
    
    # Plot 2: Noisy Decay Curves
    fig, axes = plt.subplots(2, 2, figsize=(14, 10), dpi=150)
    axes = axes.flatten()
    tau_array = np.logspace(-6, -2, 100)
    for idx, C in enumerate([1e-8, 1e-6, 1e-4, 1e-2]):
        T1_eff, _ = sim.compute_T1_effective(C, ParamagneticSpecies("Gd3+"))
        res = sim.simulate_pulse_sequence(T1_eff, tau_array)
        fit = sim.fit_T1(tau_array, res['fluorescence_contrast_noisy'])
        axes[idx].plot(tau_array*1e6, res['fluorescence_contrast'], 'g-', label='Ideal', alpha=0.7)
        axes[idx].plot(tau_array*1e6, res['fluorescence_contrast_noisy'], 'rx', label='Noisy Data')
        axes[idx].plot(tau_array*1e6, np.exp(-tau_array/fit['T1_fitted']), 'b--', label=f"Fit: {fit['T1_fitted']*1e3:.2f}ms")
        axes[idx].set_xscale('log')
        axes[idx].set_title(f'Decay Curve C={C:.1e}', fontweight='bold')
        axes[idx].legend()
        axes[idx].grid(alpha=0.3)
    plt.savefig('./05_T1_Decay_Curves.png', bbox_inches='tight')

    # Plot 3: Protein Corona
    fig, axes = plt.subplots(1, 2, figsize=(14, 5), dpi=150)
    T1_clean_arr, T1_cor_arr, loss = [], [], []
    for C in C_range:
        tc, tcor = sim.protein_corona_effect(C, ParamagneticSpecies("Gd3+"))
        T1_clean_arr.append(tc)
        T1_cor_arr.append(tcor)
        loss.append((tc - tcor) / tc * 100)
    axes[0].loglog(C_range, np.array(T1_clean_arr)*1e3, 'g-', label='No Corona', linewidth=2.5)
    axes[0].loglog(C_range, np.array(T1_cor_arr)*1e3, 'r-', label='2nm Corona', linewidth=2.5)
    axes[0].set_title('Protein Corona Penalty', fontweight='bold')
    axes[0].legend()
    axes[0].grid(alpha=0.3)
    axes[1].semilogx(C_range, loss, 'purple', linewidth=2.5)
    axes[1].fill_between(C_range, 0, loss, alpha=0.3, color='purple')
    axes[1].set_title('Sensitivity Loss (%)', fontweight='bold')
    axes[1].grid(alpha=0.3)
    plt.savefig('./06_Protein_Corona_Effect.png', bbox_inches='tight')
    plt.show()

if __name__ == "__main__":
    run_all_plots()
